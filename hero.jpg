<!DOCTYPE html>
<html lang="en-AU">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Garage Cleanout Sydney from $350 | SGRR | Call 0424 203 013</title>
<meta name="description" content="Sydney's trusted garage cleanout & rubbish removal. Same day available, fully insured, 5-star rated. Jobs from $350. Call 0424 203 013.">
<meta name="theme-color" content="#0F1A2E">

<!-- Open Graph -->
<meta property="og:title" content="Garage Cleanout Sydney from $350 | SGRR">
<meta property="og:description" content="Sydney's trusted garage cleanout & rubbish removal. You point, we load. Same day service available across all of Sydney.">
<meta property="og:type" content="website">
<meta property="og:image" content="assets/hero.jpg">
<meta name="twitter:card" content="summary_large_image">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter+Tight:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="preload" as="image" href="assets/hero.jpg" fetchpriority="high">
<link rel="stylesheet" href="styles.css">

<!-- JSON-LD: LocalBusiness -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "https://sgrr.com.au/#business",
  "name": "Sydney Garage & Rubbish Removal",
  "alternateName": "SGRR",
  "description": "Sydney's trusted garage cleanout and rubbish removal service. Locally owned, fully insured, 5-star rated.",
  "image": "assets/hero.jpg",
  "logo": "assets/logo.png",
  "url": "https://sgrr.com.au/",
  "telephone": "+61424203013",
  "priceRange": "$350 - $1500+",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Sydney",
    "addressRegion": "NSW",
    "addressCountry": "AU"
  },
  "areaServed": {
    "@type": "City",
    "name": "Sydney"
  },
  "openingHoursSpecification": [
    {"@type":"OpeningHoursSpecification","dayOfWeek":["Monday","Tuesday","Wednesday","Thursday","Friday"],"opens":"07:00","closes":"19:00"},
    {"@type":"OpeningHoursSpecification","dayOfWeek":["Saturday","Sunday"],"opens":"08:00","closes":"17:00"}
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5.0",
    "reviewCount": "50",
    "bestRating": "5",
    "worstRating": "1"
  }
}
</script>

<!-- JSON-LD: FAQPage -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"How much does a garage cleanout cost?","acceptedAnswer":{"@type":"Answer","text":"Pricing is based on volume. Small loads start from $350, a typical full garage cleanout runs $550–$950, and larger clearances are $1,000+. Send photos for a firm upfront quote — no hidden fees."}},
    {"@type":"Question","name":"Can you do same-day service?","acceptedAnswer":{"@type":"Answer","text":"Yes — same-day service is often available, especially when you book before midday. We operate 7 days a week across all of Greater Sydney."}},
    {"@type":"Question","name":"Do I need to move my rubbish to the kerb?","acceptedAnswer":{"@type":"Answer","text":"No — you don't move a thing. You point, we load. Our team handles all lifting and carrying, whether the items are in the garage, backyard, upstairs or in storage."}},
    {"@type":"Question","name":"How long does a garage cleanout take?","acceptedAnswer":{"@type":"Answer","text":"Most jobs take 1–3 hours from arrival to clean-swept floor. A full garage with heavy items may take up to half a day. We give you a time estimate with your quote."}},
    {"@type":"Question","name":"Is rubbish removal better than a skip bin?","acceptedAnswer":{"@type":"Answer","text":"For most homeowners, yes. You skip the heavy lifting, the week-long eyesore, the council permit, and paying for any space you didn't use. We arrive, load it all, and leave the same day."}},
    {"@type":"Question","name":"Do you provide a tax invoice?","acceptedAnswer":{"@type":"Answer","text":"Yes — a proper GST tax invoice is provided for every job. Useful for rental end-of-lease, estate clearances, and business claims."}}
  ]
}
</script>
</head>
<body>

<!-- SVG ICON SPRITE -->
<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <!-- phone -->
    <symbol id="i-phone" viewBox="0 0 24 24"><path d="M22 16.9v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.9Z"/></symbol>
    <!-- check -->
    <symbol id="i-check" viewBox="0 0 24 24"><path d="m5 12 4 4L19 6"/></symbol>
    <!-- x / close -->
    <symbol id="i-x" viewBox="0 0 24 24"><path d="M18 6 6 18M6 6l12 12"/></symbol>
    <!-- arrow-right -->
    <symbol id="i-arrow" viewBox="0 0 24 24"><path d="M5 12h14M13 5l7 7-7 7"/></symbol>
    <!-- camera -->
    <symbol id="i-camera" viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2Z"/><circle cx="12" cy="13" r="4"/></symbol>
    <!-- map-pin -->
    <symbol id="i-pin" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0Z"/><circle cx="12" cy="10" r="3"/></symbol>
    <!-- shield -->
    <symbol id="i-shield" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/></symbol>
    <!-- clock -->
    <symbol id="i-clock" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></symbol>
    <!-- bolt -->
    <symbol id="i-bolt" viewBox="0 0 24 24"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8Z"/></symbol>
    <!-- star -->
    <symbol id="i-star" viewBox="0 0 24 24"><path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2Z" fill="currentColor" stroke="none"/></symbol>
    <!-- truck -->
    <symbol id="i-truck" viewBox="0 0 24 24"><path d="M1 3h15v13H1zM16 8h4l3 3v5h-7"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></symbol>
    <!-- chat -->
    <symbol id="i-chat" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2Z"/></symbol>
    <!-- calendar -->
    <symbol id="i-calendar" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></symbol>
    <!-- broom / sparkle -->
    <symbol id="i-sparkle" viewBox="0 0 24 24"><path d="M12 3v4M12 17v4M3 12h4M17 12h4M5.6 5.6l2.8 2.8M15.6 15.6l2.8 2.8M5.6 18.4l2.8-2.8M15.6 8.4l2.8-2.8"/></symbol>
    <!-- services icons -->
    <symbol id="s-sofa" viewBox="0 0 24 24"><path d="M3 11V8a3 3 0 0 1 3-3h12a3 3 0 0 1 3 3v3"/><path d="M2 11a2 2 0 0 1 2 2v3h16v-3a2 2 0 0 1 4 0v5H2Z"/><path d="M6 19v2M18 19v2"/></symbol>
    <symbol id="s-fridge" viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M5 10h14M9 6v1M9 14v3"/></symbol>
    <symbol id="s-tv" viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="14" rx="2"/><path d="M8 21h8M12 18v3"/></symbol>
    <symbol id="s-dumbbell" viewBox="0 0 24 24"><path d="M6 7v10M10 5v14M14 5v14M18 7v10M2 10v4M22 10v4"/></symbol>
    <symbol id="s-wood" viewBox="0 0 24 24"><path d="M4 5h16M4 10h16M4 15h16M4 20h16"/><path d="M8 5v15M16 5v15"/></symbol>
    <symbol id="s-box" viewBox="0 0 24 24"><path d="M21 8 12 3 3 8v8l9 5 9-5Z"/><path d="M3 8l9 5 9-5M12 13v8"/></symbol>
    <!-- upload -->
    <symbol id="i-upload" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v13"/></symbol>
  </defs>
</svg>

