<!-- HERO -->
<section class="hero" id="top">
  <div class="hero-bg" role="img" aria-label="SGRR team loading a washing machine into a branded truck"></div>
  <div class="hero-overlay"></div>
  <div class="hero-grid">
    <div class="hero-copy">
      <div class="hero-badge">
        <span class="hero-badge-dot" aria-hidden="true"></span>
        Available today across Sydney · Reply in 30 min
      </div>
      <h1 class="hero-h1">You point.<br><em>We load.</em></h1>
      <p class="hero-sub">Full garage cleanouts and rubbish removal across all of Sydney. A local team doing all the heavy lifting &mdash; fast, honest, done.</p>
      <div class="hero-price-row">
        <div>
          <div class="hero-price-label">Jobs from</div>
          <div class="hero-price-num">$350</div>
        </div>
        <div style="margin-left:auto;text-align:right">
          <div class="hero-price-label">Same-day</div>
          <div style="font-family:var(--serif);font-size:24px;color:rgba(255,255,255,.9);margin-top:4px">Available</div>
        </div>
      </div>
      <div class="hero-btns">
        <a href="#quote" class="btn btn-primary">
          Get a free quote
          <svg class="ic" style="width:16px;height:16px"><use href="#i-arrow"/></svg>
        </a>
        <a href="tel:0424203013" class="btn btn-ghost-dark">
          <svg class="ic" style="width:16px;height:16px"><use href="#i-phone"/></svg>
          0424 203 013
        </a>
      </div>
      <div class="hero-proof">
        <div class="hero-stars" aria-label="5 out of 5 stars">
          <svg class="ic" style="width:14px;height:14px;color:#FBBF24"><use href="#i-star"/></svg>
          <svg class="ic" style="width:14px;height:14px;color:#FBBF24"><use href="#i-star"/></svg>
          <svg class="ic" style="width:14px;height:14px;color:#FBBF24"><use href="#i-star"/></svg>
          <svg class="ic" style="width:14px;height:14px;color:#FBBF24"><use href="#i-star"/></svg>
          <svg class="ic" style="width:14px;height:14px;color:#FBBF24"><use href="#i-star"/></svg>
        </div>
        <span><strong style="color:rgba(255,255,255,.9)">5.0</strong> · 50+ Google reviews</span>
      </div>
    </div>

    <!-- QUOTE CARD -->
    <form class="quote-card" id="quote" onsubmit="return submitQuote(event)">
      <div class="qc-head">
        <div class="qc-title">Get your <em>firm</em> quote</div>
        <div class="qc-sub">Reply in 30 min · No obligation · Send photos for an exact price</div>
      </div>
      <div class="qc-fields" id="qc-fields">
        <div class="field">
          <label>Your name</label>
          <input type="text" name="name" placeholder="e.g. Sarah Mitchell" autocomplete="name" required>
        </div>
        <div class="qc-row">
          <div class="field">
            <label>Mobile</label>
            <input type="tel" name="phone" placeholder="0400 000 000" autocomplete="tel" required>
          </div>
          <div class="field">
            <label>Suburb</label>
            <input type="text" name="suburb" placeholder="Parramatta" required>
          </div>
        </div>
        <div class="field">
          <label>What needs cleared? <span class="opt">— Be specific for a firm quote</span></label>
          <textarea name="details" placeholder="e.g. Full single-car garage cleanout, old fridge, mattress, bike, boxes of junk…" required></textarea>
        </div>
        <div class="field">
          <label>Photos <span class="opt">— Optional but gets you a faster price</span></label>
          <label for="photos" style="cursor:pointer;display:flex;align-items:center;gap:10px;padding:13px 14px;border:1.5px dashed var(--line-2);border-radius:10px;background:#FAF7F1;color:var(--ink-soft);font-size:14px;font-family:var(--sans);text-transform:none;letter-spacing:0;font-weight:400;margin-bottom:0">
            <svg class="ic" style="width:18px;height:18px;color:var(--orange)"><use href="#i-upload"/></svg>
            <span id="photos-label">Upload photos of the space</span>
          </label>
          <input type="file" id="photos" name="photos" multiple accept="image/*" style="display:none" onchange="onPhotos(this)">
        </div>
      </div>
      <div class="qc-actions" id="qc-actions">
        <button type="submit" class="btn btn-primary qc-submit">
          Send &amp; get my quote
          <svg class="ic" style="width:16px;height:16px"><use href="#i-arrow"/></svg>
        </button>
        <div class="qc-meta">
          <svg class="ic" style="width:14px;height:14px;color:var(--orange)"><use href="#i-shield"/></svg>
          We never share your details · Fully insured
        </div>
      </div>
      <div class="qc-success" id="qc-success" role="status" aria-live="polite">
        <div class="qc-success-icon">
          <svg class="ic" style="width:28px;height:28px;stroke-width:2.2"><use href="#i-check"/></svg>
        </div>
        <h3>Got it — we're on it.</h3>
        <p>We've received your request and will reply with a firm quote within <strong>30 minutes</strong> (usually much faster).</p>
        <a href="tel:0424203013" class="qc-success-cta">
          <svg class="ic" style="width:16px;height:16px"><use href="#i-phone"/></svg>
          Or call us now on 0424 203 013
        </a>
      </div>
    </form>
  </div>
</section>

<!-- COMPARE -->
<section class="section bg-paper" id="why-us">
  <div class="section-wrap">
    <span class="eyebrow">Why SGRR</span>
    <h2 class="h2">Skip bin, or <em>sorted today?</em></h2>
    <p class="lede">Thinking about a skip bin? Here's what most Sydney homeowners find out the hard way — and why a phone call to SGRR wins every time.</p>

    <div class="compare-grid">
      <div class="compare-card them">
        <div class="compare-head">
          <svg class="ic" style="width:14px;height:14px"><use href="#i-x"/></svg>
          The skip-bin way
        </div>
        <h3>A week of problems</h3>
        <div class="compare-list">
          <div class="compare-row"><span class="compare-icon"><svg class="ic" style="width:14px;height:14px;stroke-width:2.2"><use href="#i-x"/></svg></span><span>You do all the heavy lifting yourself</span></div>
          <div class="compare-row"><span class="compare-icon"><svg class="ic" style="width:14px;height:14px;stroke-width:2.2"><use href="#i-x"/></svg></span><span>Bin sits out front for a week — or longer</span></div>
          <div class="compare-row"><span class="compare-icon"><svg class="ic" style="width:14px;height:14px;stroke-width:2.2"><use href="#i-x"/></svg></span><span>Neighbours fill it with their own junk overnight</span></div>
          <div class="compare-row"><span class="compare-icon"><svg class="ic" style="width:14px;height:14px;stroke-width:2.2"><use href="#i-x"/></svg></span><span>Council permits if it sits on the nature strip</span></div>
          <div class="compare-row"><span class="compare-icon"><svg class="ic" style="width:14px;height:14px;stroke-width:2.2"><use href="#i-x"/></svg></span><span>No fridges, mattresses, tyres or e-waste</span></div>
          <div class="compare-row"><span class="compare-icon"><svg class="ic" style="width:14px;height:14px;stroke-width:2.2"><use href="#i-x"/></svg></span><span>Pay for the whole bin, even half-full</span></div>
        </div>
      </div>

      <div class="compare-card us">
        <div class="compare-head">
          <svg class="ic" style="width:14px;height:14px"><use href="#i-check"/></svg>
          The SGRR way
        </div>
        <h3>Done by <em>dinner</em></h3>
        <div class="compare-list">
          <div class="compare-row"><span class="compare-icon"><svg class="ic" style="width:14px;height:14px;stroke-width:2.2"><use href="#i-check"/></svg></span><span>We do all the heavy lifting — you don't move a thing</span></div>
          <div class="compare-row"><span class="compare-icon"><svg class="ic" style="width:14px;height:14px;stroke-width:2.2"><use href="#i-check"/></svg></span><span>We come and go same day — in and out in hours</span></div>
          <div class="compare-row"><span class="compare-icon"><svg class="ic" style="width:14px;height:14px;stroke-width:2.2"><use href="#i-check"/></svg></span><span>You only pay for your rubbish — never the neighbour's</span></div>
          <div class="compare-row"><span class="compare-icon"><svg class="ic" style="width:14px;height:14px;stroke-width:2.2"><use href="#i-check"/></svg></span><span>No permits, no approvals — we handle everything</span></div>
          <div class="compare-row"><span class="compare-icon"><svg class="ic" style="width:14px;height:14px;stroke-width:2.2"><use href="#i-check"/></svg></span><span>We take fridges, mattresses, tyres and e-waste</span></div>
          <div class="compare-row"><span class="compare-icon"><svg class="ic" style="width:14px;height:14px;stroke-width:2.2"><use href="#i-check"/></svg></span><span>Same-day service anywhere in Greater Sydney</span></div>
        </div>
      </div>
    </div>

    <div class="compare-footer">
      <p><strong>Bottom line.</strong> No heavy lifting. No bin blocking the drive for a week. No paying for the neighbour's junk. SGRR is the smarter call, every time.</p>
      <a href="#quote" class="btn btn-primary">Get a free quote <svg class="ic" style="width:16px;height:16px"><use href="#i-arrow"/></svg></a>
    </div>
  </div>
</section>

<!-- PROCESS -->
<section class="section bg-cream" id="process">
  <div class="section-wrap">
    <span class="eyebrow">The Process</span>
    <h2 class="h2">Three steps to a <em>clear</em> garage</h2>
    <p class="lede">From your first message to a spotless space — simple, fast, completely stress-free.</p>

    <div class="process-list">
      <div class="process-card">
        <span class="process-num">01</span>
        <h3>Send a message</h3>
        <p>Fill in the form, text a few photos, or call. We reply with a firm upfront price — no surprises, no fine print.</p>
        <div class="process-note">
          <svg class="ic" style="width:16px;height:16px"><use href="#i-chat"/></svg>
          <span>Firm quote in 30 min or less</span>
        </div>
      </div>
      <div class="process-card">
        <span class="process-num">02</span>
        <h3>Pick your day</h3>
        <p>We work seven days a week and can often come same-day or next morning. Morning or afternoon slot — you choose.</p>
        <div class="process-note">
          <svg class="ic" style="width:16px;height:16px"><use href="#i-calendar"/></svg>
          <span>Same-day service often available</span>
        </div>
      </div>
      <div class="process-card">
        <span class="process-num">03</span>
        <h3>We clear it</h3>
        <p>Our uniformed team arrives on time, loads every last item, and sweeps up after. You don't lift a finger.</p>
        <div class="process-note">
          <svg class="ic" style="width:16px;height:16px"><use href="#i-sparkle"/></svg>
          <span>Floor swept clean before we leave</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- PRICING -->
<section class="section bg-navy" id="pricing">
  <div class="section-wrap">
    <span class="eyebrow">Transparent Pricing</span>
    <h2 class="h2 white">Simple, <em>upfront</em> pricing</h2>
    <p class="lede white">No hidden fees. No surprises. We give you a firm quote before we start — and we always stick to it.</p>

    <div class="pricing-grid">
      <div class="price-card">
        <div class="pc-name">Small Load</div>
        <div class="pc-desc">A few items — furniture, single appliance or mixed boxes</div>
        <div class="pc-from">Starting from</div>
        <div class="pc-price">$350<span class="range"> – $550</span></div>
        <div class="pc-includes">
          <div class="pc-include"><svg class="ic" style="width:16px;height:16px"><use href="#i-check"/></svg><span>Same-day service available</span></div>
          <div class="pc-include"><svg class="ic" style="width:16px;height:16px"><use href="#i-check"/></svg><span>We do all the loading</span></div>
          <div class="pc-include"><svg class="ic" style="width:16px;height:16px"><use href="#i-check"/></svg><span>Firm upfront quote</span></div>
        </div>
      </div>
      <div class="price-card featured">
        <div class="pc-badge">Most Popular</div>
        <div class="pc-name">Garage Cleanout</div>
        <div class="pc-desc">Full or partial garage — mixed items, bulky rubbish, shelving</div>
        <div class="pc-from">Starting from</div>
        <div class="pc-price">$550<span class="range"> – $950</span></div>
        <div class="pc-includes">
          <div class="pc-include"><svg class="ic" style="width:16px;height:16px"><use href="#i-check"/></svg><span>Same-day service available</span></div>
          <div class="pc-include"><svg class="ic" style="width:16px;height:16px"><use href="#i-check"/></svg><span>Full cleanout — every last item</span></div>
          <div class="pc-include"><svg class="ic" style="width:16px;height:16px"><use href="#i-check"/></svg><span>Floor swept clean after</span></div>
          <div class="pc-include"><svg class="ic" style="width:16px;height:16px"><use href="#i-check"/></svg><span>Firm upfront quote</span></div>
        </div>
      </div>
      <div class="price-card">
        <div class="pc-name">Large Cleanout</div>
        <div class="pc-desc">Heavy items, disassembly, full property or estate clearance</div>
        <div class="pc-from">Starting from</div>
        <div class="pc-price">$1,000<span class="range">+</span></div>
        <div class="pc-includes">
          <div class="pc-include"><svg class="ic" style="width:16px;height:16px"><use href="#i-check"/></svg><span>Disassembly included</span></div>
          <div class="pc-include"><svg class="ic" style="width:16px;height:16px"><use href="#i-check"/></svg><span>All heavy items covered</span></div>
          <div class="pc-include"><svg class="ic" style="width:16px;height:16px"><use href="#i-check"/></svg><span>Firm upfront quote</span></div>
        </div>
      </div>
    </div>

