<script>
function faq(btn){
  const item = btn.parentElement;
  const open = item.classList.toggle('open');
  btn.setAttribute('aria-expanded', open ? 'true' : 'false');
}

function onPhotos(input){
  const label = document.getElementById('photos-label');
  const n = input.files ? input.files.length : 0;
  label.textContent = n ? (n + ' photo' + (n>1?'s':'') + ' attached') : 'Upload photos of the space';
}

function submitQuote(e){
  e.preventDefault();
  const form = e.target;
  const fields = document.getElementById('qc-fields');
  const actions = document.getElementById('qc-actions');
  const success = document.getElementById('qc-success');

  // In production: POST to your backend / Formspree / Netlify.
  // For now: simulate success.
  fields.classList.add('hide');
  actions.classList.add('hide');
  success.classList.add('show');

  return false;
}
</script>
